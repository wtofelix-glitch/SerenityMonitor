# SerenityMonitor local environment template.
# Copy to .env for local use; keep real token values out of git.

# Dashboard write APIs: /api/trades, /api/config, /api/execute
SERENITY_DASHBOARD_TOKEN=replace-with-long-random-token

# Bridge write/task APIs: /api/send and /api/serenity/*
SERENITY_BRIDGE_TOKEN=replace-with-another-long-random-token

# Optional shared fallback used by both dashboard and bridge when specific
# tokens above are not set.
# SERENITY_API_TOKEN=replace-with-shared-token

# Optional runtime tuning.
SERENITY_DASHBOARD_PORT=8401
SERENITY_MONITOR_API_TIMEOUT=7

# Telegram 推送
TELEGRAM_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# DeepSeek AI（因子解读）
DEEPSEEK_API_KEY=sk-your-key-here
